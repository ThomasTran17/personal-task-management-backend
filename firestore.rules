rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read and write for authenticated users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Task security rules
    match /tasks/{taskId} {
      // Allow read if user is owner or participant
      allow read: if request.auth != null && 
                     (resource.data.ownerId == request.auth.uid || 
                      request.auth.uid in resource.data.participantIds);
      
      // Allow create for authenticated users
      allow create: if request.auth != null &&
                       request.data.ownerId == request.auth.uid &&
                       request.data.keys().hasAll(['title', 'ownerId', 'status', 'priority', 'participantIds', 'createdAt', 'updatedAt']);
      
      // Allow update only by owner
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid;
      
      // Allow delete only by owner
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
      
      // Subtask creation rules: allow ONLY IF parent task owner matches current user
      allow write: if request.auth != null &&
                      request.data.parentId != null &&
                      exists(/databases/$(database)/documents/tasks/$(request.data.parentId)) &&
                      get(/databases/$(database)/documents/tasks/$(request.data.parentId)).data.ownerId == request.auth.uid;
    }

    // Deny all other requests
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
