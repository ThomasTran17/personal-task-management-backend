PORT=3000

# Firebase Configuration
# Found in: project_id
FIREBASE_PROJECT_ID=your-project-id-123

# Found in: private_key_id
FIREBASE_PRIVATE_KEY_ID=1a2b3c4d5e6f7g8h9i0j

# Found in: private_key
# IMPORTANT: Must be wrapped in quotes and include the \n characters
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ...\n-----END PRIVATE KEY-----\n"

# Found in: client_email
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Found in: client_id
FIREBASE_CLIENT_ID=12345678901234567890

# Found in: auth_uri
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth

# Found in: token_uri (Use this for FIREBASE_SERVICE_ACCOUNT_URI usually)
FIREBASE_SERVICE_ACCOUNT_URI=https://oauth2.googleapis.com/token

# Found in: auth_provider_x509_cert_url
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs

# Found in: client_x509_cert_url
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project-id.iam.gserviceaccount.com

# Environment
NODE_ENV=development